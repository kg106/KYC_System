# ============================================================
# Makefile — KYC System Docker Commands
# Usage: make <target>
# ============================================================

.PHONY: help build up down logs shell clean restart rebuild status \
        monitoring monitoring-down logs-prometheus logs-loki logs-promtail logs-grafana

# Default target
help:
	@echo ""
	@echo "  KYC System — Docker Commands"
	@echo "  ─────────────────────────────────────────"
	@echo "  make build           Build the Docker image"
	@echo "  make up              Start all services (detached)"
	@echo "  make down            Stop and remove containers"
	@echo "  make restart         Restart the app container only"
	@echo "  make rebuild         Rebuild image + restart app"
	@echo "  make logs            Tail logs from all services"
	@echo "  make logs-app        Tail logs from app only"
	@echo "  make shell           Open shell in app container"
	@echo "  make db-shell        Open psql shell in postgres"
	@echo "  make status          Show running containers"
	@echo "  make clean           Remove containers, volumes, images"
	@echo ""
	@echo "  ── Monitoring ──────────────────────────────"
	@echo "  make monitoring      Start only Prometheus + Loki + Promtail + Grafana"
	@echo "  make monitoring-down Stop monitoring stack only"
	@echo "  make logs-prometheus Tail Prometheus logs"
	@echo "  make logs-loki       Tail Loki logs"
	@echo "  make logs-promtail   Tail Promtail logs"
	@echo "  make logs-grafana    Tail Grafana logs"
	@echo ""

# ── App ──────────────────────────────────────────────────────────────────────

build:
	docker compose build --no-cache

up:
	docker compose up -d
	@echo "✅ Services started."
	@echo "   App:        http://localhost:8080"
	@echo "   Swagger:    http://localhost:8080/swagger-ui.html"
	@echo "   Prometheus: http://localhost:9090"
	@echo "   Grafana:    http://localhost:3000  (admin/admin)"
	@echo "   Loki:       http://localhost:3100"

tools:
	docker compose --profile tools up -d
	@echo "✅ pgAdmin: http://localhost:5050"

down:
	docker compose down

logs:
	docker compose logs -f

logs-app:
	docker compose logs -f kyc-app

restart:
	docker compose restart kyc-app

rebuild:
	docker compose build kyc-app
	docker compose up -d --no-deps kyc-app

shell:
	docker exec -it kyc_application /bin/sh

db-shell:
	docker exec -it kyc_postgres psql -U $${POSTGRES_USER:-kyc_user} -d $${POSTGRES_DB:-kyc_db}

status:
	docker compose ps

clean:
	docker compose down -v --rmi local
	@echo "🧹 Cleaned up containers, volumes, and local images"

# ── Monitoring ───────────────────────────────────────────────────────────────
# Start only the monitoring stack — useful when running the app locally
# with: ./mvnw spring-boot:run -Dspring-boot.run.profiles=dev

monitoring:
	docker compose up -d prometheus loki promtail grafana
	@echo "✅ Monitoring stack started."
	@echo "   Prometheus: http://localhost:9090"
	@echo "   Loki:       http://localhost:3100"
	@echo "   Grafana:    http://localhost:3000  (admin/admin)"
	@echo ""
	@echo "   Check Prometheus targets: http://localhost:9090/targets"
	@echo "   Check Loki status:        http://localhost:3100/ready"

monitoring-down:
	docker compose stop prometheus loki promtail grafana

logs-prometheus:
	docker compose logs -f prometheus

logs-loki:
	docker compose logs -f loki

logs-promtail:
	docker compose logs -f promtail

logs-grafana:
	docker compose logs -f grafana