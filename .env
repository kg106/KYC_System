# Environment variables for KYC System Docker setup
# Copy this file to .env and update the values as needed

# PostgreSQL Database Configuration
# POSTGRES_DB=kyc_db_copy
# POSTGRES_USER=test_user
# POSTGRES_PASSWORD=system

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/kyc_db_copy
SPRING_DATASOURCE_USERNAME=test_user
SPRING_DATASOURCE_PASSWORD=system

# JWT Configuration
APP_JWT_SECRET=566d626154316a4c6a6d61324e6a41324e6a41324e6a41324e6a41324e6a41324e6a41324e6a41324e6a41324e6a4132
APP_JWT_EXPIRATION_MILLISECONDS=900000
# Encryption Secret
APP_ENCRYPTION_SECRET=your-encryption-secret-key-32-characters-long!

# Mail Configuration (Gmail SMTP)
MAIL_USERNAME=your-gmail-username@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Spring Profile
SPRING_PROFILES_ACTIVE=docker
